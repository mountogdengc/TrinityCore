# Copy to ".env" and adjust. Compose reads this automatically.

############################
# TrinityCore source
############################
# Branch to build. "master" targets the current retail client
# (e.g. 12.0.5 build 67823).
TC_BRANCH=master
# Cap parallel compile jobs to limit RAM use (empty = all cores).
BUILD_JOBS=

############################
# Database
############################
MYSQL_ROOT_PASSWORD=rootpass
TC_DB_USER=trinity
TC_DB_PASSWORD=trinity
TC_AUTH_DB=auth
TC_CHARACTERS_DB=characters
TC_WORLD_DB=world

############################
# TDB (full world database)
############################
# URL of the TDB release .7z that matches your TC_BRANCH. On first launch the
# worldserver downloads + imports it into an empty `world` DB. Find the right
# asset at https://github.com/TrinityCore/TrinityCore/releases
# Example:
# TC_TDB_URL=https://github.com/TrinityCore/TrinityCore/releases/download/TDB1300.00/TDB_full_world_1300.00_2025_06_01.7z
TC_TDB_URL=

############################
# Client data extraction
############################
# Path to your legally-obtained retail WoW client (contains the "Data" folder).
WOW_CLIENT_DIR=./wow-client

############################
# SOAP remote console
############################
# Used by `./tc account` and `./tc cmd`. Authenticates with an existing GM
# account (create the first one via `./tc console`).
TC_SOAP_ENABLED=1
TC_SOAP_PORT=7878
# Credentials ./tc uses to talk to SOAP (must be an existing account with the
# required GM level / RBAC permissions).
TC_SOAP_USER=admin
TC_SOAP_PASSWORD=admin

############################
# Host port mappings
############################
MYSQL_PORT=3306
AUTH_PORT=3724
WORLD_PORT=8085
SOAP_PORT=7878
