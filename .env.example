# Copy to ".env" and adjust. Compose reads this automatically.

############################
# TrinityCore source
############################
# This repository now contains the TrinityCore source tree directly.
# Docker builds the currently checked-out local source rather than cloning upstream.
# Cap parallel compile jobs to limit RAM use (empty = all cores).
BUILD_JOBS=

############################
# Database
############################
MYSQL_ROOT_PASSWORD=rootpass
TC_DB_USER=trinity
TC_DB_PASSWORD=trinity
TC_AUTH_DB=auth
TC_CHARACTERS_DB=characters
TC_WORLD_DB=world
# Retail/master uses a 4th database for client data hotfixes.
TC_HOTFIX_DB=hotfixes

############################
# TDB (full world database)
############################
# URL of the TDB release .7z that matches your checked-out TrinityCore branch. On first launch the
# worldserver downloads + imports it into an empty `world` DB. Find the right
# asset at https://github.com/TrinityCore/TrinityCore/releases
# Example:
# TC_TDB_URL=https://github.com/TrinityCore/TrinityCore/releases/download/TDB1300.00/TDB_full_world_1300.00_2025_06_01.7z
TC_TDB_URL=

############################
# Client data extraction
############################
# Path to your legally-obtained retail WoW client (contains the "Data" folder).
WOW_CLIENT_DIR=./wow-client

############################
# Player-bot overlay
############################
# Build the experimental headless player-bot overlay into the image (1=on, 0=off).
# Commands in-world (GM): .bot add/remove/count. See overlay/README.md.
BOTS_OVERLAY=1

############################
# Host port mappings
############################
# Retail/master runs bnetserver (Battle.net login), not the legacy authserver:
#   BNET_PORT = battle.net, LOGIN_REST_PORT = login REST (HTTPS).
MYSQL_PORT=3306
BNET_PORT=1119
LOGIN_REST_PORT=8081
WORLD_PORT=8085
# SOAP remote console (used by the ./tc helper CLI).
SOAP_PORT=7878
